---
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const dispatches = posts.length;
const lastPublished = posts[0]?.data.pubDate.toLocaleDateString('en-GB', {
  day: '2-digit', month: 'short', year: 'numeric'
}) ?? '—';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Company of Feathers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Share+Tech+Mono&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #111110;
      --bg-card: #161614;
      --bg-card-hover: #1c1c1a;
      --border: rgba(255,255,255,0.08);
      --border-hover: rgba(255,255,255,0.15);
      --text-primary: #e8e4dc;
      --text-secondary: #8a8680;
      --text-muted: #555250;
      --accent: #c9b99a;
      --accent-dim: rgba(201,185,154,0.15);
      --serif: 'EB Garamond', Georgia, serif;
      --mono: 'Share Tech Mono', monospace;
      --sans: 'DM Sans', sans-serif;
    }

    html {
      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--sans);
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
    }

    body {
      min-height: 100vh;
    }

    /* ── NAV ── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 68px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg);
    }

    .nav-logo {
      font-family: var(--serif);
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--text-primary);
      letter-spacing: 0.01em;
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--sans);
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--text-secondary);
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--text-primary);
    }

    .nav-menu-btn {
      width: 28px;
      height: 28px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 3px;
      transition: border-color 0.2s;
    }

    .nav-menu-btn:hover {
      border-color: var(--border-hover);
    }

    .nav-menu-btn span {
      display: block;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--text-secondary);
    }

    /* ── HERO ── */
    .hero {
      padding: 5rem 3rem 4rem;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: end;
    }

    .hero-left {}

    .hero-headline {
      font-family: var(--serif);
      font-size: clamp(3rem, 6vw, 4.5rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.01em;
      margin-bottom: 3rem;
    }

    .hero-headline em {
      font-style: italic;
      color: var(--text-secondary);
    }

    .hero-stats {
      display: flex;
      gap: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .stat-label {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }

    .stat-value {
      font-family: var(--sans);
      font-size: 1rem;
      font-weight: 400;
      color: var(--text-primary);
    }

    .stat-value.active {
      color: #7dc97d;
    }

    .hero-right {
      padding-bottom: 0.5rem;
    }

    .hero-description {
      font-family: var(--sans);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-secondary);
      font-weight: 300;
      max-width: 340px;
    }

    /* ── POSTS GRID ── */
    .posts-section {
      padding: 0 3rem 5rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2rem 0 2rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0;
    }

    .section-label {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    .section-link {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .section-link:hover {
      color: var(--accent);
    }

    .posts-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      border-left: 1px solid var(--border);
    }

    /* ── POST CARD ── */
    .post-card {
      display: block;
      text-decoration: none;
      color: inherit;
      padding: 2.5rem 2rem;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      position: relative;
      transition: background 0.25s;
      overflow: hidden;
    }

    .post-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--accent-dim);
      opacity: 0;
      transition: opacity 0.25s;
    }

    .post-card:hover {
      background: var(--bg-card-hover);
    }

    .post-card:hover::before {
      opacity: 1;
    }

    .post-card.featured {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
      padding: 3rem 2rem;
    }

    .post-card.featured .post-title {
      font-size: 1.9rem;
    }

    .post-card.featured .post-excerpt {
      display: block;
    }

    .post-index {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .post-category {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.9rem;
    }

    .post-title {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 400;
      line-height: 1.3;
      color: var(--text-primary);
      margin-bottom: 1rem;
      letter-spacing: -0.01em;
    }

    .post-excerpt {
      font-family: var(--sans);
      font-size: 0.82rem;
      line-height: 1.7;
      color: var(--text-secondary);
      font-weight: 300;
      display: none;
      margin-bottom: 1.5rem;
    }

    .post-meta {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-top: auto;
    }

    /* Featured card right column */
    .post-card.featured .featured-right {
      padding-top: 0.2rem;
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-copy {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }

    .footer-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .footer-links a {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links a:hover {
      color: var(--text-secondary);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 0 1.5rem; }
      .hero { grid-template-columns: 1fr; padding: 3rem 1.5rem; gap: 2rem; }
      .posts-section { padding: 0 1.5rem 3rem; }
      .posts-grid { grid-template-columns: 1fr; }
      .post-card.featured { grid-column: 1; display: block; }
      footer { padding: 1.5rem; flex-direction: column; gap: 1rem; align-items: flex-start; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">Company of Feathers</a>
    <ul class="nav-links">
      <li><a href="/writing">Writing</a></li>
      <li><a href="/archive">Archive</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/rss.xml">RSS</a></li>
    </ul>
    <button class="nav-menu-btn" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- HERO -->
  <header class="hero">
    <div class="hero-left">
      <h1 class="hero-headline">
        Thoughts,<br />
        <em>dispatched</em><br />
        as found.
      </h1>
      <div class="hero-stats">
        <div>
          <div class="stat-label">Dispatches</div>
          <div class="stat-value">{dispatches}</div>
        </div>
        <div>
          <div class="stat-label">Last Published</div>
          <div class="stat-value">{lastPublished}</div>
        </div>
        <div>
          <div class="stat-label">Status</div>
          <div class="stat-value active">Active</div>
        </div>
      </div>
    </div>
    <div class="hero-right">
      <p class="hero-description">
        A field log of ideas, observations, and slow
        analysis — written without agenda, published
        without schedule.
      </p>
    </div>
  </header>

  <!-- POSTS -->
  <main class="posts-section">
    <div class="section-header">
      <span class="section-label">Recent Dispatches</span>
      <a href="/archive" class="section-link">Full Archive →</a>
    </div>

    <div class="posts-grid">
      {posts.slice(0, 3).map((post, i) => (
        i === 0 ? (
          <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} ...>
            <div>
              <div class="post-index">ENTRY · {String(dispatches - i).padStart(3, '0')}</div>
              <div class="post-category">DISPATCH</div>
              <div class="post-title">{post.data.title}</div>
            </div>
            <div class="featured-right">
              <div class="post-excerpt">{post.data.description}</div>
              <div class="post-meta">
                <span>{post.data.pubDate.toLocaleDateString('en-GB')}</span>
              </div>
            </div>
          </a>
        ) : (
          <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} ...>
            <div class="post-index">ENTRY · {String(dispatches - i).padStart(3, '0')}</div>
            <div class="post-category">DISPATCH</div>
            <div class="post-title">{post.data.title}</div>
            <div class="post-excerpt">{post.data.description}</div>
            <div class="post-meta">
              <span>{post.data.pubDate.toLocaleDateString('en-GB')}</span>
            </div>
          </a>
        )
      ))}
    </div>
  </main>

  <!-- FOOTER -->
  <footer>
    <span class="footer-copy">© {new Date().getFullYear()} Company of Feathers</span>
    <ul class="footer-links">
      <li><a href="/writing">Writing</a></li>
      <li><a href="/archive">Archive</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/rss.xml">RSS</a></li>
    </ul>
  </footer>

</body>
</html>